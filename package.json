{
  "name": "marketing-os",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Production-grade multi-tenant AI Marketing SaaS platform",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "dev:server": "cd server && DOTENV_CONFIG_PATH=../.env npm run dev",
    "build:server": "cd server && npm run build",
    "start:server": "cd server && npm start",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "db:migrate": "cd server && npm run db:migrate",
    "install:all": "npm install && cd server && npm install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.4.5",
    "vite": "^5.4.0"
  }
}
