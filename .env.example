# =============================================
# Marketing OS - Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git.

# ── Frontend (Vite) ──────────────────────────
# These are bundled into the client — only use for PUBLIC values
VITE_API_URL=/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Backend ──────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Supabase (server-only) ──────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── AI (server-only) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Stripe (server-only) ────────────────────
# Must be sk_test_* or sk_live_*, NOT pk_*
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── CORS ────────────────────────────────────
# Comma-separated list of allowed origins. NO wildcard in production.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── Google Ads (optional) ─────────────────────
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=https://your-domain.com/api/integrations/google/callback

# ── SEMrush (optional) ───────────────────────
# SEMRUSH_API_KEY=your-semrush-api-key

# ── Frontend URL (for OAuth redirects) ───────
# FRONTEND_URL=https://marketingos-smoky.vercel.app

# ── PageSpeed Insights (optional) ───────────
# Leave blank for free tier (rate-limited)
# PAGESPEED_API_KEY=

# ── Meta / Facebook (optional) ──────────────
# META_APP_ID=your-meta-app-id
# META_APP_SECRET=your-meta-app-secret
# META_REDIRECT_URI=http://localhost:4000/api/meta/oauth/callback

# ── Admin bypass (optional, dev/staging only) ─
# Remove these in production unless strictly needed
# ADMIN_SECRET=
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# ── Rate limits (optional) ──────────────────
# DAILY_USER_GENERATION_CAP=50
# MONTHLY_ORG_TOKEN_CAP=5000000
